# 环境变量配置示例
# 复制此文件为 .env 并修改配置

# 应用配置
APP_NAME=股票涨停统计分析系统
DEBUG=true

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/stock_limit_up.db

# 通达信配置
TDX_HOST=119.147.212.81
TDX_PORT=7709

# 爬虫配置
CRAWLER_INTERVAL_THS=300
CRAWLER_INTERVAL_KPL=600
CRAWLER_REQUEST_TIMEOUT=30

# Tushare 配置（用于盘前流通股本/可流通交易值）
TUSHARE_TOKEN=

# DeepSeek 总结配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_REQUEST_TIMEOUT=60

# ima 知识库增量同步配置
INTELLIGENCE_ENABLED=true
IMA_DAILY_REVIEW_SHARE_ID=12d27469b8ae3e0fae5d6ce8242cff813010a6a5b8bf3248155c1487f099bace
IMA_JIEGE_SHARE_ID=8fbac3ae9fb49b7d2d76a8e22f6bf866d83963ed7a9534f4d1057886fc13d161
IMA_SYNC_PAGE_SIZE=20
IMA_SYNC_MAX_PAGES=20

# Level-2采集配置
L2_COLLECT_INTERVAL=3

# 大单默认阈值
DEFAULT_BIG_ORDER_THRESHOLD=500000
DEFAULT_BIG_ORDER_VOLUME=1000

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
